T3CODE_HOST=127.0.0.1
T3CODE_PORT=3773
T3CODE_NO_BROWSER=1
T3CODE_AUTH_TOKEN=replace-with-a-long-random-token
T3CODE_APP_AUTH_USERNAME=replace-with-your-login-username
T3CODE_APP_AUTH_PASSWORD=replace-with-your-login-password
# Optional. Falls back to T3CODE_AUTH_TOKEN when omitted.
T3CODE_APP_AUTH_SESSION_SECRET=replace-with-a-session-secret
T3CODE_APP_AUTH_SESSION_TTL_DAYS=30
T3CODE_VAPID_PUBLIC_KEY=replace-with-your-vapid-public-key
T3CODE_VAPID_PRIVATE_KEY=replace-with-your-vapid-private-key
T3CODE_VAPID_SUBJECT=mailto:you@thewrighthome.app
